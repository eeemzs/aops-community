{
  "name": "@aopslab/aops-server",
  "version": "0.1.4",
  "type": "module",
  "description": "AOPS Community loopback server.",
  "keywords": [
    "aops",
    "ai-operations",
    "server"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eeemzs/aops-community.git",
    "directory": "apps/aops-server"
  },
  "engines": {
    "node": ">=22.9.0"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "vite dev --host 127.0.0.1",
    "build": "svelte-kit sync && vite build",
    "test:host": "node --test --experimental-strip-types test/community-host.test.mjs test/runtime-config.test.mjs",
    "test:gateway": "node --test --experimental-strip-types src/lib/agent-gateway/helpers.test.ts",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "start": "node ./scripts/community-host.mjs"
  },
  "dependencies": {
    "@aops/error-catalog": "workspace:*",
    "@aops/host-registration": "workspace:*",
    "@aops/pg-bootstrap": "workspace:*",
    "@aopslab/domain-host-plugin-agentspace": "0.1.1",
    "@aopslab/domain-host-plugin-chatv3": "0.1.1",
    "@aopslab/domain-host-plugin-docman": "0.1.4",
    "@aopslab/domain-host-plugin-projectman": "0.0.4",
    "@aopslab/domain-host-plugin-sys": "0.0.6",
    "@aopslab/domain-kit-agentspace": "0.1.1",
    "@aopslab/domain-kit-chatv3": "0.1.1",
    "@aopslab/domain-pg-bootstrap-chatv3": "0.1.1",
    "@aopslab/domain-pg-bootstrap-projectman": "0.1.0",
    "@aopslab/domain-kit-docman": "0.1.4",
    "@aopslab/domain-kit-projectman": "0.1.5",
    "@aopslab/domain-kit-sys": "0.0.5",
    "@aopslab/domain-pg-bootstrap-sys": "0.1.0",
    "@aopslab/domain-pg-bootstrap-docman": "0.1.0",
    "@aopslab/domain-product-docman": "0.1.0",
    "@aopslab/domain-product-projectman": "0.1.1",
    "@aopslab/domain-runtime-config-docman": "0.1.0",
    "@aopslab/domain-runtime-config-projectman": "0.1.0",
    "@aopslab/host-adapter-sveltekit": "0.1.1",
    "@aopslab/host-core": "0.1.1",
    "@aopslab/manifest": "0.1.3",
    "@aopslab/xf-dm-kits": "0.1.14",
    "@aopslab/xf-logger": "0.1.61",
    "ajv": "8.18.0",
    "effect": "3.20.0",
    "pg": "8.20.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "5.5.7",
    "@sveltejs/kit": "2.70.1",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@types/node": "25.3.1",
    "@types/pg": "8.16.0",
    "svelte-check": "4.4.4",
    "svelte": "5.56.7",
    "typescript": "5.9.3",
    "vite": "7.3.6"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
