{
  "name": "@aopslab/aops-cli",
  "version": "0.1.7",
  "private": true,
  "type": "module",
  "description": "AOPS Community operator CLI.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eeemzs/aops-community.git",
    "directory": "apps/aops-cli"
  },
  "bin": {
    "aops": "dist/main.js",
    "aops-cli": "dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --incremental false",
    "test:assets-menu": "node --test test/assets-menu.test.mjs",
    "test:agent-assets-content": "node --test test/agent-assets-content.test.mjs",
    "test:cockpit": "node --test test/cockpit.test.mjs",
    "test:setup-install": "node --test test/setup-install.test.mjs",
    "test:skill-discovery": "node --test test/skill-discovery.test.mjs",
    "test:container-runtime": "node --test test/container-runtime.test.mjs",
    "test:home": "node --test test/home-menu.test.mjs",
    "test:shortcuts": "pnpm run test:home && pnpm run test:cockpit && pnpm run test:assets-menu && pnpm run test:agent-assets-content && pnpm run test:setup-install && pnpm run test:skill-discovery",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@aopslab/aops-server": "workspace:*",
    "@aops/host-registration": "workspace:*",
    "@aops/pg-bootstrap": "workspace:*",
    "@aops/runtime-config": "workspace:*",
    "@sigstore/bundle": "4.0.0",
    "@sigstore/protobuf-specs": "0.5.1",
    "@sigstore/tuf": "4.0.2",
    "@sigstore/verify": "3.1.1",
    "@aopslab/api-client": "workspace:*",
    "@aopslab/domain-product-client-chatv3": "0.1.1",
    "@aopslab/xf-cli-operator": "0.0.2",
    "@aopslab/xf-cli-ui": "0.1.13",
    "commander": "14.0.3",
    "inquirer": "13.3.0",
    "pg": "8.20.0",
    "sigstore": "4.1.1"
  },
  "devDependencies": {
    "@types/node": "25.3.1",
    "@types/pg": "8.20.0",
    "typescript": "5.9.3"
  }
}
