    "@aopslab/cli-kit": "workspace:*",
    "@aopslab/domain-product-client-chatv3": "workspace:*",
    "@aopslab/xf-cli-operator": "0.0.2",
    "@aopslab/xf-cli-ui": "0.1.13",
    "@aopslab/xf-secure-store": "0.1.27",
    "commander": "14.0.3",
    "inquirer": "13.3.0",
    "sigstore": "4.1.1"
  },
  "devDependencies": {
    "@types/node": "25.3.1",
    "typescript": "5.9.3"
  }
