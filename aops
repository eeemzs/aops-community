#!/bin/sh
set -eu

AOPS_CLONE_ROOT=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
AOPS_CLI_ENTRY="$AOPS_CLONE_ROOT/apps/aops-cli/dist/main.js"
if [ ! -f "$AOPS_CLI_ENTRY" ]; then
  echo "aops-cli is not built; run pnpm install --frozen-lockfile first" >&2
  exit 1
fi
exec node "$AOPS_CLI_ENTRY" "$@"
