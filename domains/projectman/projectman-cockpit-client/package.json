{
  "name": "@aopslab/projectman-cockpit-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Thin read-only Projectman client over @aopslab/light-client-core: typed board/sprint/task/issue/feedback/review-request reads against the hosted /api/projectman surface. Read-only by design (F3 f3-pm-client v0).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@aopslab/light-client-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eeemzs/aops-community.git",
    "directory": "domains/projectman/projectman-cockpit-client"
  }
}
