{
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": [
      "es2022"
    ],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": [
      "development"
    ],
    "paths": {
      "@aopslab/domain-runtime-config-projectman": [
        "projectman-runtime-config/src/index.ts"
      ],
      "@aopslab/domain-runtime-config-projectman/*": [
        "projectman-runtime-config/src/*"
      ],
      "@aopslab/domain-host-plugin-projectman": [
        "projectman-host-plugin/src/index.ts"
      ],
      "@aopslab/domain-host-plugin-projectman/*": [
        "projectman-host-plugin/src/*"
      ],
      "@aopslab/domain-product-projectman": [
        "projectman-product/src/index.ts"
      ],
      "@aopslab/domain-product-projectman/*": [
        "projectman-product/src/*"
      ],
      "@aopslab/domain-kit-projectman": [
        "projectman-kit/src/index.ts"
      ],
      "@aopslab/domain-kit-projectman/*": [
        "projectman-kit/src/*"
      ],
      "@aopslab/domain-dm-projectman": [
        "projectman-dm/src/index.ts"
      ],
      "@aopslab/domain-dm-projectman/models": [
        "projectman-dm/src/public/models/index.ts"
      ],
      "@aopslab/domain-dm-projectman/ports": [
        "projectman-dm/src/public/ports/index.ts"
      ],
      "@aopslab/domain-dm-projectman/repository-ports": [
        "projectman-dm/src/public/repository-ports/index.ts"
      ],
      "@aopslab/domain-dm-projectman/services": [
        "projectman-dm/src/public/services/index.ts"
      ],
      "@aopslab/domain-dm-projectman/factories": [
        "projectman-dm/src/public/factories/index.ts"
      ]
    }
  }
}
