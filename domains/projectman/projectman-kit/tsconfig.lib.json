{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": false,
    "declarationMap": false,
    "sourceMap": false,
    "declaration": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"],
    "incremental": true,
    "paths": {
      "@aopslab/domain-dm-projectman/ports": ["../projectman-dm/src/public/ports/index.ts"],
      "@aopslab/domain-dm-projectman/repository-ports": ["../projectman-dm/src/public/repository-ports/index.ts"],
      "@aopslab/domain-dm-projectman/services": ["../projectman-dm/src/public/services/index.ts"],
      "@aopslab/domain-dm-projectman/factories": ["../projectman-dm/src/public/factories/index.ts"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../projectman-dm/tsconfig.lib.json" }
  ],
  "exclude": [
    "out-tsc",
    "dist",
    "jest.config.ts",
    "src/__tests__/**",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ]
}
