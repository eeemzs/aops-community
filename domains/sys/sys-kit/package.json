{
  "name": "@aopslab/domain-kit-sys",
  "version": "0.0.5",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b tsconfig.lib.json"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js",
      "default": "./dist/errors/index.js"
    },
    "./errors/i18n": {
      "types": "./dist/errors/i18n.d.ts",
      "import": "./dist/errors/i18n.js",
      "default": "./dist/errors/i18n.js"
    },
    "./resources": {
      "types": "./dist/resources/index.d.ts",
      "import": "./dist/resources/index.js",
      "default": "./dist/resources/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo",
    "!**/.syncthing*",
    "LICENSE",
    "NOTICE"
  ],
  "dependencies": {
    "@aopslab/domain-dm-sys": "workspace:*",
    "@aopslab/xf-core": "catalog:",
    "@aopslab/xf-db": "catalog:",
    "@aopslab/xf-db-redis": "catalog:",
    "@aopslab/xf-dm-kits": "catalog:",
    "@aopslab/xf-i18n": "catalog:",
    "@aopslab/xf-logger": "catalog:",
    "@aopslab/xf-validation": "catalog:",
    "dotenv": "catalog:",
    "tslib": "catalog:",
    "effect": "catalog:",
    "zod": "catalog:"
  },
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eeemzs/aops-community.git",
    "directory": "domains/sys/sys-kit"
  }
}
