{
  "name": "@aopslab/domain-host-plugin-sys",
  "version": "0.0.6",
  "type": "module",
  "private": true,
  "description": "Sys host plugin (manifest-driven routing).",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "node --eval \"const { rmSync } = require('node:fs'); rmSync('dist', { recursive: true, force: true });\"",
    "build": "node --eval \"const { rmSync } = require('node:fs'); rmSync('dist', { recursive: true, force: true });\" && tsc -b tsconfig.lib.json",
    "prepack": "npm run build"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo",
    "LICENSE",
    "NOTICE"
  ],
  "dependencies": {
    "@aopslab/domain-kit-sys": "workspace:*",
    "@aopslab/domain-pg-bootstrap-sys": "workspace:*",
    "@aopslab/xf-validation": "workspace:*",
    "zod": "catalog:"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eeemzs/aops-community.git",
    "directory": "domains/sys/sys-host-plugin"
  }
}
