{
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": [
      "es2022"
    ],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": [
      "development"
    ],
    "paths": {
      "@aopslab/domain-host-plugin-sys": [
        "sys-host-plugin/src/index.ts"
      ],
      "@aopslab/domain-host-plugin-sys/*": [
        "sys-host-plugin/src/*"
      ],
      "@aopslab/domain-kit-sys": [
        "sys-kit/src/index.ts"
      ],
      "@aopslab/domain-kit-sys/*": [
        "sys-kit/src/*"
      ],
      "@aopslab/domain-dm-sys": [
        "sys-dm/src/index.ts"
      ],
      "@aopslab/domain-dm-sys/models": [
        "sys-dm/src/public/models/index.ts"
      ],
      "@aopslab/domain-dm-sys/ports": [
        "sys-dm/src/public/ports/index.ts"
      ],
      "@aopslab/domain-dm-sys/repository-ports": [
        "sys-dm/src/public/repository-ports/index.ts"
      ],
      "@aopslab/domain-dm-sys/services": [
        "sys-dm/src/public/services/index.ts"
      ],
      "@aopslab/domain-dm-sys/factories": [
        "sys-dm/src/public/factories/index.ts"
      ]
    }
  }
}
