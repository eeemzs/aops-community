{
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["development"],
    "paths": {
      "@aopslab/domain-tooling-agentspace": ["agentspace-tooling/src/index.ts"],
      "@aopslab/domain-tooling-agentspace/*": ["agentspace-tooling/src/*"],
      "@aopslab/domain-cli-agentspace": ["agentspace-cli/src/main.ts"],
      "@aopslab/domain-kit-agentspace": ["agentspace-kit/src/index.ts"],
      "@aopslab/domain-kit-agentspace/*": ["agentspace-kit/src/*"],
      "@aopslab/domain-dm-agentspace": ["agentspace-dm/src/index.ts"],
      "@aopslab/domain-dm-agentspace/models": ["agentspace-dm/src/public/models/index.ts"],
      "@aopslab/domain-dm-agentspace/ports": ["agentspace-dm/src/public/ports/index.ts"],
      "@aopslab/domain-dm-agentspace/repository-ports": ["agentspace-dm/src/public/repository-ports/index.ts"],
      "@aopslab/domain-dm-agentspace/services": ["agentspace-dm/src/public/services/index.ts"],
      "@aopslab/domain-dm-agentspace/factories": ["agentspace-dm/src/public/factories/index.ts"]
    }
  }
}
