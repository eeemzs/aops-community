{
  "name": "@aopslab/domain-product-docman",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Reusable host-side product controllers for Docman UI flows.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b tsconfig.lib.json"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo",
    "LICENSE",
    "NOTICE"
  ],
  "dependencies": {
    "@aopslab/domain-core-docman": "workspace:*",
    "@aopslab/domain-kit-docman": "workspace:*"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eeemzs/aops-community.git",
    "directory": "domains/docman/docman-product"
  }
}
